# Copy to .env on your GCP VM before: docker compose -f docker-compose.prod.yml up -d --build
#
# Do NOT set FASTAPI_BASE_URL here — docker-compose.prod.yml sets http://fastapi:8000 for Spring.
# A localhost value in .env would override that and break Spring → FastAPI.

# Public Spring URL (Swagger + must match Vercel VITE_API_BASE_URL)
# Use https:// once you terminate TLS (Cloudflare Tunnel — see DEPLOY.md)
SERVER_URL=https://api.yourdomain.com

# Vercel app origin(s), comma-separated (REST + WebSockets go through Spring)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Comma-separated HTTP proxies for nba_api (optional)
NBA_API_PROXY=
