# Copy to .env before: docker compose -f docker-compose.prod.yml up -d --build
#
# Do NOT set FASTAPI_BASE_URL here — docker-compose.prod.yml sets http://fastapi:8000 for Spring.
# A localhost value in .env would override that and break Spring → FastAPI.

# Public Spring URL (Swagger; must match frontend VITE_API_BASE_URL)
SERVER_URL=https://api.yourdomain.com

# Frontend origin(s), comma-separated (REST + WebSockets go through Spring)
CORS_ALLOWED_ORIGINS=https://your-app.example.com

# Comma-separated HTTP proxies for nba_api (optional)
NBA_API_PROXY=
