# Copy to .env on your GCP VM before: docker compose -f docker-compose.prod.yml up -d --build
#
# Do NOT set FASTAPI_BASE_URL here — Spring prod profile uses http://fastapi:8000 on the Docker network.
# A value like http://localhost:8000 in .env overrides that and breaks Spring → FastAPI.

# Public Spring URL (Swagger + must match what Vercel uses for VITE_API_BASE_URL)
# Use https:// once you terminate TLS (Caddy / Cloudflare Tunnel — see DEPLOY.md)
SERVER_URL=https://api.yourdomain.com

# Vercel app origin(s), comma-separated
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Browser WebSockets hit FastAPI directly — include the same Vercel origin(s)
ALLOWED_ORIGINS=https://your-app.vercel.app

NBA_API_PROXY=
