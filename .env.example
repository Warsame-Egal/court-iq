# Spring Boot → FastAPI (local host run; Docker Compose overrides this)
FASTAPI_BASE_URL=http://localhost:8000

# Public Spring URL (Swagger server list; production: your tunnel or domain)
SERVER_URL=http://localhost:8080

# Comma-separated HTTP proxies for nba_api (optional; see nba-api/patch_http.py)
NBA_API_PROXY=

# Spring Boot CORS — comma-separated browser origins allowed to call Spring
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
