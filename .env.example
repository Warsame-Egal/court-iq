# Spring Boot → FastAPI connection
FASTAPI_BASE_URL=http://localhost:8000

# Public Spring URL (Swagger server list). Production: https://api.yourdomain.com (see DEPLOY.md)
SERVER_URL=http://localhost:8080

# NBA API patches (FastAPI / docker-compose only — leave blank for local dev)
# On container start: patch_scoreboard.py always runs; patch_http.py runs only when
# Set NBA_API_PROXY when hosting in the cloud (also accepts legacy name NBA_API_CONFIG in compose).
# Comma-separated proxy URLs, e.g. http://user:pass@host:port,http://host2:port
NBA_API_PROXY=

# Spring Boot CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# FastAPI CORS (comma-separated origins, Spring Boot only in production)
ALLOWED_ORIGINS=http://localhost:8080
